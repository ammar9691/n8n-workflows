        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"channel\": \"{{ $env.SLACK_CHANNEL_ID }}\",\n  \"text\": \"New blog post ready to publish: {{ $('Normalize Source').first().json.title }}\",\n  \"blocks\": [\n    { \"type\": \"header\", \"text\": { \"type\": \"plain_text\", \"text\": \"Approve social publish?\" } },\n    { \"type\": \"section\", \"text\": { \"type\": \"mrkdwn\", \"text\": \"*Post:* {{ $('Normalize Source').first().json.title }}\\n*URL:* {{ $('Normalize Source').first().json.url }}\" } },\n    { \"type\": \"section\", \"text\": { \"type\": \"mrkdwn\", \"text\": \"*Facebook:*\\n{{ JSON.stringify($json.facebook.message).slice(1,400) }}\" } },\n    { \"type\": \"section\", \"text\": { \"type\": \"mrkdwn\", \"text\": \"*Instagram:*\\n{{ JSON.stringify($json.instagram.caption).slice(1,400) }}\" } },\n    { \"type\": \"section\", \"text\": { \"type\": \"mrkdwn\", \"text\": \"*X thread ({{ $json.x.tweets.length }} tweets):*\\n{{ JSON.stringify($json.x.tweets.map(t => t.text).join(' || ')).slice(1,400) }}\" } },\n    { \"type\": \"section\", \"text\": { \"type\": \"mrkdwn\", \"text\": \"*LinkedIn:*\\n{{ JSON.stringify($json.linkedin.text).slice(1,400) }}\" } },\n    { \"type\": \"actions\", \"elements\": [\n      { \"type\": \"button\", \"style\": \"primary\", \"text\": { \"type\": \"plain_text\", \"text\": \"Approve\" }, \"url\": \"{{ $execution.resumeUrl }}?decision=approve\" },\n      { \"type\": \"button\", \"style\": \"danger\", \"text\": { \"type\": \"plain_text\", \"text\": \"Reject\" }, \"url\": \"{{ $execution.resumeUrl }}?decision=reject\" }\n    ] }\n  ]\n}",
        "options": {}
