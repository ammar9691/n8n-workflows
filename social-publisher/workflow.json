      "parameters": {
        "jsCode": "// Collapse the X loop results into one summary item for this branch.\nconst items = $input.all();\nconst ids = items.map(i => i.json?.data?.id).filter(Boolean);\nreturn [{ json: { platform: 'x', ok: ids.length > 0, post_ids: ids, count: ids.length } }];"
      },
      "id": "node-0180",
      "name": "Collect X Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3040, 80]
    },
    {
      "parameters": {
        "numberInputs": 4,
        "options": {}
      },
      "id": "node-0190",
      "name": "Merge Results",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [3320, -40]
    },
    {
      "parameters": {
        "jsCode": "// Normalize every branch into a common {platform, ok, post_id|post_ids, error} record.\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json || {};\n  if (j.platform === 'x') { out.push({ platform: 'x', ok: !!j.ok, post_ids: j.post_ids || [], post_id: (j.post_ids || [])[0] || null }); continue; }\n  if (j.id && /^\\d+_\\d+$/.test(String(j.id))) { out.push({ platform: 'facebook', ok: true, post_id: j.id }); continue; }\n  if (j.id && !j.error) { out.push({ platform: 'instagram', ok: true, post_id: j.id }); continue; }\n  if (j.id && j.id.startsWith && j.id.startsWith('urn:li:share')) { out.push({ platform: 'linkedin', ok: true, post_id: j.id }); continue; }\n  if (j.error) { out.push({ platform: j.platform || 'unknown', ok: false, error: typeof j.error === 'string' ? j.error : JSON.stringify(j.error) }); continue; }\n  out.push({ platform: j.platform || 'unknown', ok: !j.error, post_id: j.id || null, raw: j });\n}\nconst src = $('Normalize Source').first().json;\nreturn [{ json: {\n  title: src.title,\n  url: src.url,\n  published_at: new Date().toISOString(),\n  results: out,\n  succeeded: out.filter(r => r.ok).map(r => r.platform),\n  failed: out.filter(r => !r.ok).map(r => r.platform)\n} }];"
      },
      "id": "node-0200",
      "name": "Collect Post IDs & Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3600, -40]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.TRACKING_SHEET_WEBHOOK }}",
