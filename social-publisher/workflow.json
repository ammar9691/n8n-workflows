              "type": "array"
            }
          ]
        },
        "options": {}
      },
      "id": "node-0020",
      "name": "Normalize Source",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [240, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.OPENAI_MODEL || 'gpt-4o' }}\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"temperature\": 0.7,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a senior social media copywriter. Given a blog post, return STRICT JSON with platform-tailored copy. Schema: {\\\"facebook\\\":{\\\"text\\\":string},\\\"instagram\\\":{\\\"caption\\\":string},\\\"x\\\":{\\\"thread\\\":[string]},\\\"linkedin\\\":{\\\"text\\\":string},\\\"hashtags\\\":[string]}. The X thread must be an array of 2 to 4 short tweets each under 240 chars before hashtags. Hashtags must not include the # symbol. Do not include the URL inside any text; it is appended later.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Title: {{ $json.title }}\\nExcerpt: {{ $json.excerpt }}\\nTags: {{ ($json.tags || []).join(', ') }}\"\n    }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "neverError": false
            }
          }
        }
      },
      "id": "node-0030",
      "name": "Generate Variants (LLM)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 0],
      "credentials": {
        "openAiApi": {
          "id": "OPENAI_CRED",
          "name": "OpenAI account"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "jsCode": "// Parse the LLM response, enforce per-platform rules, build payloads.\nconst src = $('Normalize Source').first().json;\nconst raw = $input.first().json;\n\n// OpenAI chat completion -> content string -> JSON\nlet content = raw?.choices?.[0]?.message?.content || raw?.message?.content || '{}';\nlet variants;\ntry { variants = JSON.parse(content); } catch (e) { throw new Error('LLM did not return valid JSON: ' + content.slice(0, 200)); }\n\nconst LIMITS = { x: 280, instagram: 2200, linkedin: 3000, facebook: 63206 };\n\nconst withUtm = (url, source) => {\n  const u = new URL(url);\n  u.searchParams.set('utm_source', source);\n  u.searchParams.set('utm_medium', 'social');\n  u.searchParams.set('utm_campaign', 'blog_autopublish');\n  return u.toString();\n};\n\nconst tags = (variants.hashtags || []).map(h => '#' + String(h).replace(/^#/, '').replace(/\\s+/g, '')).filter(Boolean);\nconst tagLine = tags.slice(0, 8).join(' ');\n\nconst clamp = (text, max) => {\n  text = (text || '').trim();\n  if (text.length <= max) return text;\n  return text.slice(0, max - 1).trimEnd() + '\\u2026';\n};\n\n// Facebook: message + link (link rendered as preview card)\nconst fbLink = withUtm(src.url, 'facebook');\nconst fbText = clamp(`${variants.facebook?.text || src.title}\\n\\n${tagLine}`, LIMITS.facebook);\n\n// Instagram: caption + tags inline (no clickable link in caption)\nconst igCaption = clamp(`${variants.instagram?.caption || src.title}\\n\\nLink in bio.\\n\\n${tagLine}`, LIMITS.instagram);\n\n// LinkedIn: text + link appended\nconst liLink = withUtm(src.url, 'linkedin');\nconst liText = clamp(`${variants.linkedin?.text || src.title}\\n\\n${liLink}\\n\\n${tagLine}`, LIMITS.linkedin);\n\n// X: thread of tweets, each clamped to 280; URL on the first tweet, tags on last\nconst xLink = withUtm(src.url, 'twitter');\nlet thread = Array.isArray(variants.x?.thread) ? variants.x.thread.slice(0, 6) : [variants.x?.text || src.title];\nthread = thread.filter(t => t && String(t).trim());\nconst tweets = thread.map((t, i) => {\n  let body = String(t).trim();\n  if (i === 0) body = clamp(body + ' ' + xLink, LIMITS.x);\n  else if (i === thread.length - 1) body = clamp(body + ' ' + tagLine, LIMITS.x);\n  else body = clamp(body, LIMITS.x);\n  return { index: i, text: body };\n});\n\nconst payload = {\n  source: { title: src.title, url: src.url, image_url: src.image_url },\n  facebook: { message: fbText, link: fbLink },\n  instagram: { caption: igCaption, image_url: src.image_url },\n  x: { tweets },\n  linkedin: { text: liText },\n  hashtags: tags\n};\n\nreturn [{ json: payload }];"
      },
